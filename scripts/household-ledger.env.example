# household-ledger — 운영 환경변수 템플릿
#
# initial-setup.sh 가 이 파일을 /etc/household-ledger/household-ledger.env 로
# 복사(600 root:root)합니다. 복사된 파일에서 CHANGE_ME / HOST 값만 채우면 됩니다.
#   sudo nano /etc/household-ledger/household-ledger.env
#
# systemd 가 EnvironmentFile 로 읽어 백엔드 프로세스에 주입합니다.

# --- App ---
APP_ENV=production
APP_DEBUG=false

# --- Database (둘 다 필요: 앱=async 엔진, alembic 도 async) ---
DATABASE_URL=postgresql+asyncpg://household_ledger:CHANGE_ME@HOST:5432/household_ledger
SYNC_DATABASE_URL=postgresql+psycopg://household_ledger:CHANGE_ME@HOST:5432/household_ledger

# --- Auth (openssl rand -base64 32 로 생성) ---
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# --- CORS (같은 도메인에서 프론트+API 서빙하면 비워둠) ---
CORS_ORIGINS=

# --- Anthropic (선택; 비우면 AI 기능 자동 비활성) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- 업로드 위치 (initial-setup.sh 가 만든 경로) ---
UPLOAD_DIR=/var/lib/household-ledger/uploads
