# Copy this file to deploy/config.env and fill in your server's values.
#   cp deploy/config.example.env deploy/config.env
# config.env is git-ignored so your server-specific settings never get committed.

# Domain that serves the app (frontend + backend, same origin).
DOMAIN=ledger.example.com

# Project context root. The frontend is served at ${DOMAIN}${CONTEXT_ROOT}/ and the
# API at ${DOMAIN}${CONTEXT_ROOT}/api/. No trailing slash.
# IMPORTANT: this MUST match frontend/app.json -> expo.experiments.baseUrl.
CONTEXT_ROOT=/household-ledger

# Absolute path to the checked-out repo ON THE SERVER.
APP_DIR=/opt/household-ledger

# Git branch to deploy.
BRANCH=main

# System user that owns APP_DIR and runs the API service.
SERVICE_USER=deploy

# Where the API process listens. Keep it on localhost; nginx reverse-proxies to it.
API_HOST=127.0.0.1
API_PORT=8000
API_WORKERS=2

# Public base URL the web app calls at build time. Usually https://DOMAIN + CONTEXT_ROOT.
# api.ts appends /api/... to this, so include the context root but no trailing slash.
API_PUBLIC_URL=https://ledger.example.com/household-ledger

# Full path to the `uv` binary available to SERVICE_USER (run `which uv`).
UV_BIN=/usr/local/bin/uv
